# MacroEdge — configurazione variabili d'ambiente
# Copia questo file in .env e compila con le tue credenziali:
#   cp .env.example .env

# ── Provider AI — scegli UNO SOLO ────────────────────────────────
# Opzioni: groq (gratis) | gemini (gratis) | mistral (gratis) | anthropic (a pagamento)
AI_PROVIDER=groq

# Groq — CONSIGLIATO (gratis, veloce) → https://console.groq.com
GROQ_API_KEY=

# Google Gemini — gratis → https://aistudio.google.com
GEMINI_API_KEY=

# Mistral — tier gratuito → https://console.mistral.ai
MISTRAL_API_KEY=

# Anthropic Claude — a pagamento → https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Telegram ──────────────────────────────────────────────────────
# 1. Scrivi a @BotFather → /newbot → copia il token
# 2. Crea un canale privato → aggiungi il bot come admin
# 3. Invia un messaggio nel canale, poi visita:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. Cerca "chat":{"id": -100XXXXXXXXX} → quello è il TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notion ────────────────────────────────────────────────────────
# 1. Vai su https://www.notion.so/my-integrations → crea integration
# 2. Copia il token (inizia con "secret_...")
# 3. Esegui: python setup_notion.py
#    → genera automaticamente i 3 ID database qui sotto
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_DB_REPORTS=
NOTION_DB_TECNICA=
NOTION_DB_NEWS=

# ── Google Sheets (opzionale, legacy) ─────────────────────────────
# Necessario solo se usi sheets_writer.py invece di notion_writer.py
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEET_ID=
